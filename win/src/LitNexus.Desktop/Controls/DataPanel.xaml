<UserControl x:Class="LitNexus.Desktop.Controls.DataPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="0"
             FontFamily="Segoe UI"
             TextOptions.TextFormattingMode="Display"
             UseLayoutRounding="True">
  <UserControl.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelSubtleBrush" Color="#F8FBFA" />
    <SolidColorBrush x:Key="InkBrush" Color="#1D302C" />
    <SolidColorBrush x:Key="MutedBrush" Color="#71817C" />
    <SolidColorBrush x:Key="LineBrush" Color="#DCE7E3" />
    <SolidColorBrush x:Key="AccentBrush" Color="#109A8D" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#DDF4F0" />
    <SolidColorBrush x:Key="WarningBrush" Color="#B26A00" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#B42318" />

    <DropShadowEffect x:Key="CardShadow"
                      Color="#18372F"
                      BlurRadius="16"
                      ShadowDepth="2"
                      Opacity="0.075" />

    <Style x:Key="CardStyle" TargetType="{x:Type Border}">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Effect" Value="{StaticResource CardShadow}" />
    </Style>

    <Style x:Key="SurfaceButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Padding" Value="13,8" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="Surface"
                    Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Surface" Property="Background" Value="#F3F8F6" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Surface" Property="Opacity" Value="0.78" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Surface" Property="Opacity" Value="0.48" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SurfaceButtonStyle}">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="Padding" Value="16,8" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#0D897E" />
          <Setter Property="BorderBrush" Value="#0D897E" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="ScopeToggleStyle" TargetType="{x:Type ToggleButton}">
      <Setter Property="Margin" Value="0,0,8,0" />
      <Setter Property="Padding" Value="13,8" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type ToggleButton}">
            <Border x:Name="ScopeSurface"
                    Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="9">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ScopeSurface" Property="Background" Value="#F3F8F6" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="ScopeSurface" Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="ScopeSurface" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="#FFFFFF" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ScopeSurface" Property="Opacity" Value="0.48" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="ExportColumnCheckBoxStyle" TargetType="{x:Type CheckBox}">
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="Padding" Value="10,7" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type CheckBox}">
            <Border x:Name="ChoiceSurface"
                    Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <StackPanel Orientation="Horizontal">
                <Border x:Name="Indicator"
                        Width="15"
                        Height="15"
                        VerticalAlignment="Center"
                        Background="#FFFFFF"
                        BorderBrush="#9AA8A3"
                        BorderThickness="1"
                        CornerRadius="4">
                  <TextBlock x:Name="CheckGlyph"
                             Text="✓"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center"
                             FontSize="10"
                             FontWeight="Bold"
                             Foreground="#FFFFFF"
                             Visibility="Collapsed" />
                </Border>
                <ContentPresenter Margin="8,0,0,0"
                                  VerticalAlignment="Center"
                                  Content="{TemplateBinding Content}"
                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                  RecognizesAccessKey="True" />
              </StackPanel>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ChoiceSurface" Property="Background" Value="#F3F8F6" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Indicator" Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="Indicator" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="CheckGlyph" Property="Visibility" Value="Visible" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ChoiceSurface" Property="Background" Value="#F3F8F6" />
                <Setter TargetName="ChoiceSurface" Property="Opacity" Value="0.78" />
                <Setter Property="Cursor" Value="Arrow" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="StatusValueStyle" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="28" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
    </Style>

    <Style x:Key="HelpMarkStyle" TargetType="{x:Type Border}">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="Margin" Value="7,2,0,0" />
      <Setter Property="BorderBrush" Value="#9AA8A3" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="ToolTip" Value="导出的 CSV 始终保留 epmc_id、include 与 tags。导回时只读取 include（yes/no）及 tags；其余列仅供阅读。" />
    </Style>
  </UserControl.Resources>

  <StackPanel>
    <Border Padding="28" Style="{StaticResource CardStyle}">
      <StackPanel>
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="状态"
                       FontSize="19"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource InkBrush}" />
            <TextBlock Margin="10,4,0,0"
                       Text="当前人工复筛进度"
                       FontSize="12"
                       Foreground="{StaticResource MutedBrush}" />
          </StackPanel>
          <Button Grid.Column="1"
                  Style="{StaticResource SurfaceButtonStyle}"
                  Padding="11,7"
                  Click="OnRefreshClick"
                  ToolTip="重新读取当前项目数据库">↻ 刷新</Button>
        </Grid>

        <Grid Margin="0,21,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Padding="17,15" Background="{StaticResource PanelSubtleBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12">
            <StackPanel>
              <TextBlock x:Name="TotalCountText" Text="—" Style="{StaticResource StatusValueStyle}" Foreground="{StaticResource AccentBrush}" />
              <TextBlock Margin="0,3,0,0" Text="总文章数" FontSize="12" Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
          </Border>
          <Border Grid.Column="2" Padding="17,15" Background="{StaticResource PanelSubtleBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12">
            <StackPanel>
              <TextBlock x:Name="PendingCountText" Text="—" Style="{StaticResource StatusValueStyle}" Foreground="{StaticResource WarningBrush}" />
              <TextBlock Margin="0,3,0,0" Text="待复筛" FontSize="12" Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
          </Border>
          <Border Grid.Column="4" Padding="17,15" Background="{StaticResource PanelSubtleBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12">
            <StackPanel>
              <TextBlock x:Name="IncludedCountText" Text="—" Style="{StaticResource StatusValueStyle}" Foreground="#148C69" />
              <TextBlock Margin="0,3,0,0" Text="纳入" FontSize="12" Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
          </Border>
          <Border Grid.Column="6" Padding="17,15" Background="{StaticResource PanelSubtleBrush}" BorderBrush="{StaticResource LineBrush}" BorderThickness="1" CornerRadius="12">
            <StackPanel>
              <TextBlock x:Name="ExcludedCountText" Text="—" Style="{StaticResource StatusValueStyle}" Foreground="#B95050" />
              <TextBlock Margin="0,3,0,0" Text="排除" FontSize="12" Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
          </Border>
        </Grid>
      </StackPanel>
    </Border>

    <Border Margin="0,20,0,0" Padding="28" Style="{StaticResource CardStyle}">
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="导出 CSV"
                     FontSize="19"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource InkBrush}" />
          <Border Style="{StaticResource HelpMarkStyle}">
            <TextBlock Text="?"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="Bold"
                       Foreground="{StaticResource MutedBrush}" />
          </Border>
        </StackPanel>
        <TextBlock Margin="0,8,0,0"
                   Text="选择范围后导出到当前项目的 exports 文件夹。范围与导出列选择会随项目保存；导出本身不会改动数据库。"
                   FontSize="13"
                   LineHeight="21"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource MutedBrush}" />

        <StackPanel Margin="0,19,0,0" Orientation="Horizontal">
          <ToggleButton x:Name="AllScopeButton" Tag="all" Style="{StaticResource ScopeToggleStyle}" Click="OnScopeClick">
            <StackPanel Orientation="Horizontal"><TextBlock Text="全部" /><TextBlock x:Name="AllScopeCountText" Margin="7,0,0,0" Text="—" /></StackPanel>
          </ToggleButton>
          <ToggleButton x:Name="PendingScopeButton" Tag="pending" Style="{StaticResource ScopeToggleStyle}" Click="OnScopeClick">
            <StackPanel Orientation="Horizontal"><TextBlock Text="待复筛" /><TextBlock x:Name="PendingScopeCountText" Margin="7,0,0,0" Text="—" /></StackPanel>
          </ToggleButton>
          <ToggleButton x:Name="IncludedScopeButton" Tag="included" Style="{StaticResource ScopeToggleStyle}" Click="OnScopeClick">
            <StackPanel Orientation="Horizontal"><TextBlock Text="纳入" /><TextBlock x:Name="IncludedScopeCountText" Margin="7,0,0,0" Text="—" /></StackPanel>
          </ToggleButton>
          <ToggleButton x:Name="ExcludedScopeButton" Tag="excluded" Style="{StaticResource ScopeToggleStyle}" Margin="0" Click="OnScopeClick">
            <StackPanel Orientation="Horizontal"><TextBlock Text="排除" /><TextBlock x:Name="ExcludedScopeCountText" Margin="7,0,0,0" Text="—" /></StackPanel>
          </ToggleButton>
        </StackPanel>

        <Expander x:Name="ExportColumnsExpander"
                  Margin="0,18,0,0"
                  IsExpanded="False">
          <Expander.Header>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="选择导出列"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource InkBrush}" />
              <TextBlock x:Name="ExportColumnsSummaryText"
                         Margin="9,1,0,0"
                         FontSize="12"
                         Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
          </Expander.Header>
          <Border Margin="0,10,0,0"
                  Padding="14,14,14,6"
                  Background="{StaticResource PanelSubtleBrush}"
                  BorderBrush="{StaticResource LineBrush}"
                  BorderThickness="1"
                  CornerRadius="10">
            <StackPanel>
              <TextBlock Text="勾选会写入 CSV 的文章字段。AI 问题的答案与理由列由“配置 → 分类”中的导出开关单独控制。"
                         FontSize="12"
                         LineHeight="19"
                         TextWrapping="Wrap"
                         Foreground="{StaticResource MutedBrush}" />
              <WrapPanel x:Name="ExportColumnsPanel"
                         Margin="0,12,0,0" />
            </StackPanel>
          </Border>
        </Expander>

        <StackPanel Margin="0,20,0,0" Orientation="Horizontal">
          <Button x:Name="ExportButton" Style="{StaticResource PrimaryButtonStyle}" Click="OnExportClick">导出 CSV</Button>
          <Button x:Name="OpenExportsButton" Margin="9,0,0,0" Style="{StaticResource SurfaceButtonStyle}" Click="OnOpenExportsClick">打开导出目录</Button>
        </StackPanel>
        <TextBlock x:Name="ExportStatusText"
                   Margin="1,13,0,0"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource MutedBrush}" />
      </StackPanel>
    </Border>

    <Border Margin="0,20,0,0" Padding="28" Style="{StaticResource CardStyle}">
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <TextBlock Text="导入复筛结果"
                     FontSize="19"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource InkBrush}" />
          <Border Margin="7,2,0,0"
                  Width="18"
                  Height="18"
                  BorderBrush="#9AA8A3"
                  BorderThickness="1"
                  CornerRadius="9"
                  ToolTip="只按 epmc_id 匹配，只读取 include（yes/no）与 tags。其他列可以编辑供阅读，但不会写回。选择文件后始终先预检，再由你确认；默认只填补数据库中的空标注。">
            <TextBlock Text="?"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="12"
                       FontWeight="Bold"
                       Foreground="{StaticResource MutedBrush}" />
          </Border>
        </StackPanel>
        <TextBlock Margin="0,8,0,0"
                   Text="选择 CSV 后只会检查格式、重复 ID、非法值、未匹配项与覆盖冲突。确认导入时会重新检查；有实际写入前会自动备份数据库。"
                   FontSize="13"
                   LineHeight="21"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource MutedBrush}" />
        <Button x:Name="ChooseReviewCsvButton"
                Margin="0,19,0,0"
                HorizontalAlignment="Left"
                Style="{StaticResource PrimaryButtonStyle}"
                Click="OnChooseReviewCsvClick">选择 CSV 并检查…</Button>
        <TextBlock x:Name="ImportStatusText"
                   Margin="1,13,0,0"
                   FontSize="12"
                   TextWrapping="Wrap"
                   Foreground="{StaticResource MutedBrush}" />
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
