<UserControl x:Class="LitNexus.Desktop.Controls.SettingsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinWidth="0"
             FontFamily="Segoe UI"
             TextOptions.TextFormattingMode="Display"
             UseLayoutRounding="True">
  <UserControl.Resources>
    <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelSubtleBrush" Color="#F8FBFA" />
    <SolidColorBrush x:Key="InkBrush" Color="#1D302C" />
    <SolidColorBrush x:Key="MutedBrush" Color="#71817C" />
    <SolidColorBrush x:Key="LineBrush" Color="#DCE7E3" />
    <SolidColorBrush x:Key="AccentBrush" Color="#109A8D" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="#DDF4F0" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#B42318" />

    <DropShadowEffect x:Key="CardShadow"
                      Color="#18372F"
                      BlurRadius="16"
                      ShadowDepth="2"
                      Opacity="0.075" />

    <Style x:Key="SettingsCardStyle" TargetType="{x:Type Border}">
      <Setter Property="Background" Value="{StaticResource PanelBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="16" />
      <Setter Property="Effect" Value="{StaticResource CardShadow}" />
    </Style>

    <Style x:Key="FieldLabelStyle" TargetType="{x:Type TextBlock}">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
    </Style>

    <Style x:Key="InputBoxStyle" TargetType="{x:Type TextBox}">
      <Setter Property="Padding" Value="11,8" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="SelectionBrush" Value="{StaticResource AccentSoftBrush}" />
      <Setter Property="CaretBrush" Value="{StaticResource InkBrush}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type TextBox}">
            <Border x:Name="InputSurface"
                    Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ScrollViewer x:Name="PART_ContentHost"
                            Focusable="False"
                            HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                            VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="InputSurface" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="InputSurface" Property="Opacity" Value="0.55" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="SurfaceButtonStyle" TargetType="{x:Type Button}">
      <Setter Property="Padding" Value="13,8" />
      <Setter Property="Background" Value="#FFFFFF" />
      <Setter Property="BorderBrush" Value="{StaticResource LineBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{StaticResource InkBrush}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="{x:Type Button}">
            <Border x:Name="Surface"
                    Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Surface" Property="Background" Value="#F3F8F6" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Surface" Property="Opacity" Value="0.78" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Surface" Property="Opacity" Value="0.48" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource SurfaceButtonStyle}">
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="Foreground" Value="#FFFFFF" />
      <Setter Property="Padding" Value="16,8" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#0D897E" />
          <Setter Property="BorderBrush" Value="#0D897E" />
        </Trigger>
      </Style.Triggers>
    </Style>
  </UserControl.Resources>

  <StackPanel>
    <Border Padding="28" Style="{StaticResource SettingsCardStyle}">
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <Border Width="36" Height="36" Background="{StaticResource AccentSoftBrush}" CornerRadius="10">
            <TextBlock Text="⌕"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource AccentBrush}" />
          </Border>
          <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="检索"
                       FontSize="19"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource InkBrush}" />
            <TextBlock Margin="0,2,0,0"
                       Text="下载窗口、期刊与关键词会随项目保存。"
                       FontSize="12"
                       Foreground="{StaticResource MutedBrush}" />
          </StackPanel>
        </StackPanel>

        <Grid Margin="0,25,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <StackPanel Grid.Column="0" Margin="0,0,18,0">
            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="下载时间窗口" />
            <TextBox x:Name="DownloadDaysText"
                     Margin="0,7,0,0"
                     Width="130"
                     Style="{StaticResource InputBoxStyle}"
                     ToolTip="0 表示仅今天；正数表示最近 N 天。" />
            <TextBlock Margin="0,7,0,0"
                       Text="单位：天；0 表示仅今天。"
                       FontSize="11"
                       Foreground="{StaticResource MutedBrush}"
                       TextWrapping="Wrap" />
          </StackPanel>
          <StackPanel Grid.Column="1">
            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="编辑说明" />
            <TextBlock Margin="0,7,0,0"
                       Text="期刊和关键词都按行保存。以 # 开头的行是注释；空行会保留，实际下载时会忽略。"
                       FontSize="12"
                       LineHeight="19"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedBrush}" />
          </StackPanel>
        </Grid>

        <TextBlock Margin="0,22,0,0" Style="{StaticResource FieldLabelStyle}" Text="期刊" />
        <TextBox x:Name="JournalsText"
                 Margin="0,7,0,0"
                 MinHeight="132"
                 MaxHeight="245"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Style="{StaticResource InputBoxStyle}"
                 ToolTip="每行一个 Europe PMC 期刊名称。" />

        <TextBlock Margin="0,22,0,0" Style="{StaticResource FieldLabelStyle}" Text="关键词检索式" />
        <TextBox x:Name="KeywordsText"
                 Margin="0,7,0,0"
                 MinHeight="132"
                 MaxHeight="245"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="NoWrap"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 Style="{StaticResource InputBoxStyle}"
                 ToolTip="每行一个 Europe PMC 检索式。" />
      </StackPanel>
    </Border>

    <Border Margin="0,20,0,0" Padding="28" Style="{StaticResource SettingsCardStyle}">
      <StackPanel>
        <StackPanel Orientation="Horizontal">
          <Border Width="36" Height="36" Background="{StaticResource AccentSoftBrush}" CornerRadius="10">
            <TextBlock Text="●"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       FontSize="16"
                       Foreground="{StaticResource AccentBrush}" />
          </Border>
          <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
            <TextBlock Text="项目强调色"
                       FontSize="19"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource InkBrush}" />
            <TextBlock Margin="0,2,0,0"
                       Text="仅保存色相；客户端会分别推导浅色和深色所需的对比度。"
                       FontSize="12"
                       Foreground="{StaticResource MutedBrush}" />
          </StackPanel>
        </StackPanel>

        <Grid Margin="0,22,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>
          <Border x:Name="AccentPreviewBorder"
                  Width="42"
                  Height="42"
                  Margin="0,0,13,0"
                  Background="{StaticResource AccentBrush}"
                  BorderBrush="{StaticResource LineBrush}"
                  BorderThickness="1"
                  CornerRadius="10" />
          <StackPanel Grid.Column="1">
            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="色相（0 到 1）" />
            <TextBox x:Name="AccentHueText"
                     Margin="0,7,0,0"
                     Style="{StaticResource InputBoxStyle}"
                     TextChanged="OnAccentHueTextChanged"
                     ToolTip="例如 0.48。留空会恢复 LitNexus 默认青绿。" />
          </StackPanel>
          <Button Grid.Column="2"
                  Margin="12,24,0,0"
                  Style="{StaticResource SurfaceButtonStyle}"
                  Click="OnResetAccentClick">恢复默认</Button>
          <TextBlock Grid.Column="3"
                     Margin="16,25,0,0"
                     VerticalAlignment="Center"
                     Text="留空为 LitNexus 默认青绿；1 会规范化保存为 0。"
                     FontSize="11"
                     Foreground="{StaticResource MutedBrush}"
                     TextWrapping="Wrap" />
        </Grid>
      </StackPanel>
    </Border>

    <StackPanel Margin="2,18,2,0" Orientation="Horizontal">
      <TextBlock x:Name="StatusText"
                 MaxWidth="520"
                 VerticalAlignment="Center"
                 FontSize="12"
                 TextWrapping="Wrap"
                 Foreground="{StaticResource MutedBrush}" />
      <Button x:Name="SaveButton"
              Margin="16,0,0,0"
              HorizontalAlignment="Right"
              Style="{StaticResource PrimaryButtonStyle}"
              Click="OnSaveClick"
              IsEnabled="False">保存配置</Button>
    </StackPanel>
  </StackPanel>
</UserControl>
